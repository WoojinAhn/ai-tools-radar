---
// site/src/components/ToolTabs.astro
import type { ToolId } from '../lib/types.ts'

interface Props {
  activeTool: ToolId
}

const { activeTool } = Astro.props
// Claude Code's canonical URL is `/`; `/claude-code/` is kept as a redirect for
// existing bookmarks. Link directly to `/` to avoid an extra navigation hop.
const tabs: { tool: ToolId; label: string; href: string }[] = [
  { tool: 'claude-code', label: 'Claude Code', href: import.meta.env.BASE_URL },
  { tool: 'cursor', label: 'Cursor', href: `${import.meta.env.BASE_URL}/cursor/` },
]
---

<nav class="flex gap-0 border-b border-neutral-800 mb-8">
  {tabs.map((tab) => (
    <a
      href={tab.href}
      class:list={[
        'px-5 py-3 text-sm transition-colors',
        activeTool === tab.tool
          ? 'text-white border-b-2 border-white font-medium'
          : 'text-neutral-500 hover:text-neutral-300',
      ]}
    >
      {tab.label}
    </a>
  ))}
</nav>
